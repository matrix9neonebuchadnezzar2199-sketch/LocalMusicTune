# LocalMusicTune configuration example
# Copy to .env and adjust paths if needed.

# Model storage directory (default: ./models relative to project root)
# LMT_MODELS_DIR=

# Generated audio output directory (default: ./outputs)
# LMT_OUTPUTS_DIR=

# Gradio server port
LMT_PORT=7860

# Hugging Face token (optional, for gated models)
# HF_TOKEN=
