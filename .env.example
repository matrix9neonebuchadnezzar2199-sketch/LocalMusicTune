# LocalMusicTune configuration example
# Copy to .env and adjust paths if needed.

# Model storage directory (default: ./models relative to project root)
# LMT_MODELS_DIR=

# Generated audio output directory (default: ./outputs)
# LMT_OUTPUTS_DIR=

# Gradio server port
LMT_PORT=7860

# UI slider defaults on first load (seconds / diffusion steps)
# LMT_UI_DURATION_SEC=30
# LMT_UI_STEPS=30

# ROCm / ACE-Step runtime (set in start_rocm.bat — PHASE 5)
# HSA_OVERRIDE_GFX_VERSION=11.0.0
# ACESTEP_LM_BACKEND=pt
# MIOPEN_FIND_MODE=FAST
# ACESTEP_INIT_LLM=false
# ACESTEP_ROCM_DTYPE=float16
# ACESTEP_ROCM_DTYPE=bfloat16
# ACESTEP_GENERATION_TIMEOUT=1800

# ACE-Step integration (install separately — see README)
# ACESTEP_CHECKPOINTS_DIR=./checkpoints
# ACESTEP_LM_MODEL=acestep-5Hz-lm-0.6B
# ACESTEP_LM_BACKEND=pt
