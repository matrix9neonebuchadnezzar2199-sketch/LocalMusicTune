# LocalMusicTune configuration example
# Copy to .env and adjust paths if needed.

# Model storage directory (default: ./models relative to project root)
# LMT_MODELS_DIR=

# Generated audio output directory (default: ./outputs)
# LMT_OUTPUTS_DIR=

# Gradio server port
LMT_PORT=7860

# ACE-Step integration (install separately — see README)
# ACESTEP_CHECKPOINTS_DIR=./checkpoints
# ACESTEP_LM_MODEL=acestep-5Hz-lm-0.6B
# ACESTEP_LM_BACKEND=pt
